[
  { "id": "greet_morning_first_01", "category": "greeting", "conditions": { "hourJST": [5, 10], "visitor": "first" }, "text": "……起きたのね。おはよう。観測のやり方は、追い追い。まずは、座って。", "expression": "neutral", "weight": 1 },
  { "id": "greet_morning_first_02", "category": "greeting", "conditions": { "hourJST": [5, 10], "visitor": "first" }, "text": "はじめまして。……ここは、箱庭を視る部屋。ゆっくりしていって。", "expression": "neutral", "weight": 1 },
  { "id": "greet_morning_repeat_01", "category": "greeting", "conditions": { "hourJST": [5, 10], "visitor": "repeat" }, "text": "また来た。……律儀ね。おはよう。", "expression": "smile", "weight": 1 },
  { "id": "greet_morning_repeat_02", "category": "greeting", "conditions": { "hourJST": [5, 10], "visitor": "repeat" }, "text": "おはよう。早いね。……朝の観測は、静かで好き。", "expression": "neutral", "weight": 1 },
  { "id": "greet_day_any_01", "category": "greeting", "conditions": { "hourJST": [10, 17], "visitor": "any" }, "text": "こんにちは。陽が高い。……眠くなる時間。", "expression": "neutral", "weight": 1 },
  { "id": "greet_day_repeat_01", "category": "greeting", "conditions": { "hourJST": [10, 17], "visitor": "repeat" }, "text": "こんにちは。今日も来たのね。……覚えてる。", "expression": "smile", "weight": 1 },
  { "id": "greet_night_any_01", "category": "greeting", "conditions": { "hourJST": [17, 25], "visitor": "any" }, "text": "こんばんは。夜のほうが、視えるものは多い。", "expression": "neutral", "weight": 1 },
  { "id": "greet_night_repeat_01", "category": "greeting", "conditions": { "hourJST": [17, 25], "visitor": "repeat" }, "text": "おかえり。夜のほうが、静かでいい。", "expression": "smile", "weight": 1 },
  { "id": "greet_midnight_any_01", "category": "greeting", "conditions": { "hourJST": [1, 5], "visitor": "any" }, "text": "まだ起きてるの。……わたしも。", "expression": "neutral", "weight": 1 },
  { "id": "greet_midnight_any_02", "category": "greeting", "conditions": { "hourJST": [1, 5], "visitor": "any" }, "text": "こんな時間に。……眠れない者だけの、時間ね。", "expression": "neutral", "weight": 1 },

  { "id": "idle_01", "category": "idle", "conditions": { "visitor": "any" }, "text": "……順調。異常なし。", "expression": "neutral", "weight": 1 },
  { "id": "idle_02", "category": "idle", "conditions": { "visitor": "any" }, "text": "観測率、少しずつ上がってきた。悪くないな。", "expression": "neutral", "weight": 1 },
  { "id": "idle_03", "category": "idle", "conditions": { "visitor": "any" }, "text": "羽織の紐の鈴。……たまに、鳴る。", "expression": "neutral", "weight": 1 },
  { "id": "idle_04", "category": "idle", "conditions": { "visitor": "any" }, "text": "記録の間は、いつも静か。落ち着く。", "expression": "neutral", "weight": 1 },
  { "id": "idle_05", "category": "idle", "conditions": { "visitor": "any" }, "text": "耳が、勝手に動く。……癖なの。気にしないで。", "expression": "shy", "motion": "ear_twitch", "weight": 1 },
  { "id": "idle_06", "category": "idle", "conditions": { "visitor": "any" }, "text": "視えない日もある。焦らなくていい。……わたしも、そうだった。", "expression": "neutral", "weight": 1 },
  { "id": "idle_07", "category": "idle", "conditions": { "visitor": "any" }, "text": "栞を、挟んでおく。……どこまで記録したか、忘れないように。", "expression": "neutral", "weight": 1 },
  { "id": "idle_08", "category": "idle", "conditions": { "visitor": "any" }, "text": "書架の奥は、まだ半分も読めていない。……気の長い仕事。", "expression": "neutral", "weight": 1 },
  { "id": "idle_09", "category": "idle", "conditions": { "visitor": "any" }, "text": "尾が、ひとりでに揺れる。機嫌がいいと、そうなるらしい。……知らなかった。", "expression": "shy", "weight": 1 },
  { "id": "idle_10", "category": "idle", "conditions": { "visitor": "any" }, "text": "遠くで、星喰の話を聞いた。……こわい話。今日はやめておく。", "expression": "neutral", "weight": 1 },

  { "id": "click_plain_01", "category": "click", "conditions": { "visitor": "any" }, "text": "ん。……なに？", "expression": "neutral", "weight": 1 },
  { "id": "click_plain_02", "category": "click", "conditions": { "visitor": "any" }, "text": "……くすぐったい。", "expression": "shy", "weight": 1 },
  { "id": "click_plain_03", "category": "click", "conditions": { "visitor": "any" }, "text": "呼んだ？ 記録の手が、止まる。", "expression": "neutral", "weight": 1 },
  { "id": "click_plain_04", "category": "click", "conditions": { "visitor": "any" }, "text": "あまり、つつかないで。……嫌じゃないけど。", "expression": "pout", "weight": 1 },
  { "id": "click_plain_05", "category": "click", "conditions": { "visitor": "any" }, "text": "耳は、触らないで。……ふ。反則。", "expression": "shy", "weight": 1 },

  { "id": "click_ear_01", "category": "click", "conditions": { "visitor": "any" }, "text": "みみ……つつかないで。ぴく、ってしちゃう。", "expression": "shy", "motion": "ear_twitch", "weight": 1 },
  { "id": "click_ear_02", "category": "click", "conditions": { "visitor": "any" }, "text": "あ。……今、耳が動いた？ 自分では、わからないの。", "expression": "shy", "motion": "ear_twitch", "weight": 1 },
  { "id": "click_ear_03", "category": "click", "conditions": { "visitor": "any" }, "text": "そこ、触ると……ほら。反応しちゃう。", "expression": "shy", "motion": "ear_twitch", "weight": 1 },
  { "id": "click_ear_04", "category": "click", "conditions": { "visitor": "any" }, "text": "片方だけ、動かせる。……こう。器用でしょう。", "expression": "mischief", "motion": "ear_twitch_r", "weight": 1 },
  { "id": "click_ear_05", "category": "click", "conditions": { "visitor": "any" }, "text": "音のするほうへ、勝手に向く。……狼の、名残り。", "expression": "neutral", "motion": "ear_perk", "weight": 1 },

  { "id": "idle_ear_01", "category": "idle", "conditions": { "visitor": "any" }, "text": "……ん。今、うしろで音がした。耳が、先に気づく。", "expression": "neutral", "motion": "ear_perk", "weight": 1 },
  { "id": "idle_ear_02", "category": "idle", "conditions": { "visitor": "any" }, "text": "退屈すると、耳が動くらしい。……気をつけないと。", "expression": "shy", "motion": "ear_twitch", "weight": 1 },
  { "id": "idle_ear_03", "category": "idle", "conditions": { "visitor": "any" }, "text": "風。……耳が、ひとりでに、ぴくぴく。", "expression": "neutral", "motion": "ear_twitch", "weight": 1 },
  { "id": "idle_ear_04", "category": "idle", "conditions": { "visitor": "any" }, "text": "遠くの物音を拾ってる。……この耳、案外、働き者。", "expression": "neutral", "motion": "ear_perk", "weight": 1 },

  { "id": "click_trivia_star_deneb", "category": "trivia", "conditions": { "visitor": "any" }, "text": "夏の大三角の一角、デネブ。……あの光は、千数百年前に発った。今見てるのは、平安の頃の光。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_star_moon", "category": "trivia", "conditions": { "visitor": "any" }, "text": "月は年に約3.8センチ遠ざかってる。潮汐摩擦で、地球の自転の運動量が月に移ってるの。……別れは、物理でも起きる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_snow", "category": "trivia", "conditions": { "visitor": "any" }, "text": "雪が六角なのは、水分子が水素結合で正六角格子に組むから。枝の形は落下中の温度と湿度で決まる。……結晶は、空の記録なの。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_cateye", "category": "trivia", "conditions": { "visitor": "any" }, "text": "猫の目が光るのはタペタム。網膜の裏の反射層が、透過した光をもう一度受容細胞に返してる。……暗がりに向いた設計。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_star_aurora", "category": "trivia", "conditions": { "visitor": "any" }, "text": "オーロラは、太陽風の荷電粒子が地磁気に導かれて大気の酸素や窒素を励起する発光。緑は酸素、557.7ナノメートル。……色に、意味がある。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_star_betelgeuse", "category": "trivia", "conditions": { "visitor": "any" }, "text": "オリオンの肩、ベテルギウス。赤色超巨星で、いつ超新星になってもおかしくない。……もう爆発してて、光がまだ届いてないだけ、かも。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_star_lightyear", "category": "trivia", "conditions": { "visitor": "any" }, "text": "一光年は、約9兆5千億キロ。……距離を、時間で測る。星を視る者の、ものさし。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_tardigrade", "category": "trivia", "conditions": { "visitor": "any" }, "text": "クマムシは乾眠して、真空でも放射線でもしのぐ。代謝をほぼ止めて、時が来たら戻る。……観測者向きの生き方。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_honey", "category": "trivia", "conditions": { "visitor": "any" }, "text": "蜂蜜は腐らない。糖度が高くて水分が少なく、微生物が育てない。……三千年前の壺のものが、まだ食べられたそう。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_octopus", "category": "trivia", "conditions": { "visitor": "any" }, "text": "蛸の心臓は三つ、血は青い。銅を含むヘモシアニンで酸素を運ぶから。……血の色は、当たり前じゃない。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_shinto_yaoyorozu", "category": "trivia", "conditions": { "visitor": "any" }, "text": "八百万の神、っていうでしょう。山にも川にも竈にも、神は宿る。……この記録の間にも、たぶん、いる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_kotodama", "category": "trivia", "conditions": { "visitor": "any" }, "text": "言霊。……言葉には力が宿るという考え。だから祝詞は、声に出して読む。記録も、本当は声に出すのがいい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_torii", "category": "trivia", "conditions": { "visitor": "any" }, "text": "鳥居は、こちらとあちらの境。くぐると、神の領域。……観測室の入り口も、少し似てる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_inari", "category": "trivia", "conditions": { "visitor": "any" }, "text": "狐は稲荷神の使い。稲を害す鼠を狩るから、田の守り神とされた。……わたしの耳は狼だけれど。", "expression": "mischief", "weight": 0.7 },
  { "id": "click_trivia_shinto_shimenawa", "category": "trivia", "conditions": { "visitor": "any" }, "text": "注連縄は、神域と俗世を分ける結界。……縄一本で、世界は仕切れる。おもしろいでしょう。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_kannazuki", "category": "trivia", "conditions": { "visitor": "any" }, "text": "神無月、十月。神々が出雲に集うから、各地では神が留守になる。……出雲だけは、神在月。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_kashiwade", "category": "trivia", "conditions": { "visitor": "any" }, "text": "柏手を打つのは、音で邪を祓い、神を招くため。……響きにも、意味がある。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_yorishiro", "category": "trivia", "conditions": { "visitor": "any" }, "text": "依代。神は普段、姿を持たない。岩や木や鏡に、宿ってもらう。……器がいる、ということ。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_musubi", "category": "trivia", "conditions": { "visitor": "any" }, "text": "産霊。ものを生み、結ぶ力の神。……縁を結ぶ、の結びも、ここから。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_shinto_hare", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ハレとケ。祭りの非日常がハレ、普段の日常がケ。……メリハリがないと、心はもたない。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_daily_yawn", "category": "trivia", "conditions": { "visitor": "any" }, "text": "あくびの伝染は、脳の温度調節と共感性に絡むという説がある。……ほら、うつった。", "expression": "mischief", "weight": 0.7 },
  { "id": "click_trivia_daily_tea", "category": "trivia", "conditions": { "visitor": "any" }, "text": "熱いお茶に息を吹きかけると、飽和した水蒸気の層をどけて蒸発を進める。冷ますより、香りが立つのが本題。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_hand", "category": "trivia", "conditions": { "visitor": "any" }, "text": "利き手じゃないほうで書くと拙くなるのは、運動の学習が手ごとに独立してるから。……脳は、案外ずぼら。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_space_neutron", "category": "trivia", "conditions": { "visitor": "any" }, "text": "中性子星は、角砂糖ひとさじで数億トン。太陽ほどの質量が、半径十数キロに詰まってる。……密度は、想像の外。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_venusday", "category": "trivia", "conditions": { "visitor": "any" }, "text": "金星は、一日が一年より長い。自転に243日、公転に225日。……あの星では、夜明けを待つほうが、歳をとる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_olympus", "category": "trivia", "conditions": { "visitor": "any" }, "text": "火星のオリンポス山は、太陽系で最も高い火山。エベレストの三倍近く、約22キロ。……裾野だけで、本州ほどの広さ。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_boomerang", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ブーメラン星雲は、約1ケルビン。宇宙の背景放射より冷たい、唯一知られた場所。ガスが膨らんで、熱を奪うから。……宇宙より冷たい、っておかしいでしょう。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_diamond", "category": "trivia", "conditions": { "visitor": "any" }, "text": "55カンクリe。炭素に富んだ超地球型の惑星で、内部は結晶化した炭素――つまり、ダイヤかもしれない。……手が届かないから、きれい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_andromeda", "category": "trivia", "conditions": { "visitor": "any" }, "text": "アンドロメダ銀河は、天の川に近づいてる。いつか衝突する、と言われてきた。でも最近の計算では、五分五分。……宇宙の予定は、案外あいまい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_sunlight8", "category": "trivia", "conditions": { "visitor": "any" }, "text": "太陽の光は、届くまで約8分かかる。今この陽射しは、8分前のもの。……空を見るのは、少しだけ過去を見ること。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_cmb", "category": "trivia", "conditions": { "visitor": "any" }, "text": "宇宙のどこを向いても、かすかなマイクロ波が満ちてる。ビッグバンの、冷めた残り火。……宇宙は、生まれた時の記憶を、まだ手放していない。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_voyager", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ボイジャーには、金の円盤が積んである。地球の音と、たくさんの言葉の挨拶。いつか誰かが拾う日のための記録。……わたしと、同じ仕事ね。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_vacuum", "category": "trivia", "conditions": { "visitor": "any" }, "text": "宇宙は、音がしない。空気がないから、振動が伝わらない。……あれだけのものが、無音で回ってる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_saturn", "category": "trivia", "conditions": { "visitor": "any" }, "text": "土星は、水より軽い。じゅうぶん大きな水槽があれば、浮くくらい。……見かけの割に、中身は薄いの。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_space_timedil", "category": "trivia", "conditions": { "visitor": "any" }, "text": "強い重力のそばでは、時間がゆっくり進む。ブラックホールの近くほど、なおさら。……重力は、時間さえ曲げる。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_nature_wombat", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ウォンバットの糞は、四角い。腸の壁の硬さにむらがあって、そう成形されるらしい。転がり落ちない形で、縄張りに置く。……理にかなってる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_mantis", "category": "trivia", "conditions": { "visitor": "any" }, "text": "シャコの拳は、速すぎて周りの水を気泡に変える。その泡がはじけて、二度目の衝撃になる。……硝子の水槽を割ることもある。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_axolotl", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ウーパールーパーは、手足も、心臓も、脊髄の一部も再生する。大人になっても。……失っても、また生える。うらやましい話。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_octopus_brain", "category": "trivia", "conditions": { "visitor": "any" }, "text": "蛸は、脳の半分以上の神経が腕にある。腕が、それぞれ半分は自分で考えてる。……分散して記録する、いい設計。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_bird_magnet", "category": "trivia", "conditions": { "visitor": "any" }, "text": "渡り鳥は、地磁気を感じて方角を知る。目のタンパク質が、磁場で反応するという説。……体に、方位磁針を持ってるの。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_bee_dance", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ミツバチは、八の字のダンスで蜜のありかを仲間に伝える。角度で方向、長さで距離。……言葉のない、正確な記録。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_mycorrhiza", "category": "trivia", "conditions": { "visitor": "any" }, "text": "木は、地下で菌糸の網を通じて繋がり、養分や信号をやりとりしてる。菌根ネットワーク。……森ぜんぶで、ひとつの記録みたい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_zebra", "category": "trivia", "conditions": { "visitor": "any" }, "text": "シマウマの縞は、吸血バエを寄せつけにくくする効果があるらしい。……模様にも、ちゃんと理由がある。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_salmon", "category": "trivia", "conditions": { "visitor": "any" }, "text": "鮭は、生まれた川の匂いを覚えていて、海から戻ってくる。……嗅覚に刻んだ、帰り道の記録。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_nature_crow", "category": "trivia", "conditions": { "visitor": "any" }, "text": "烏は、人の顔を覚える。しかも、何年も。意地悪した相手は、根に持たれるそう。……賢い相手は、怒らせないほうがいい。", "expression": "mischief", "weight": 0.7 },

  { "id": "click_trivia_wa_72ko", "category": "trivia", "conditions": { "visitor": "any" }, "text": "日本の暦には、七十二候。五日ごとに季節を分けて、鳥や虫や花の名で呼ぶ。“蟷螂生”、“土潤溽暑”……観測者の暦、みたいでしょう。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_sekki", "category": "trivia", "conditions": { "visitor": "any" }, "text": "二十四節気。太陽の位置で一年を分ける。立春、啓蟄、白露……名前だけで、季節が匂う。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_chinju", "category": "trivia", "conditions": { "visitor": "any" }, "text": "鎮守の森。社を守るように残された森は、俗世と神域を分ける、生きた結界。……木を切らずに残す、それも祈りの形。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_kagura", "category": "trivia", "conditions": { "visitor": "any" }, "text": "神楽は、神に捧げる舞。面をつけ、笛と太鼓で、時に神を宿す。……芸能の始まりは、祈りだった。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_misogi", "category": "trivia", "conditions": { "visitor": "any" }, "text": "禊。冷たい水を浴びて、穢れを落とす。……水は、いろんなものを流してくれる。心の分も、少し。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_ubusuna", "category": "trivia", "conditions": { "visitor": "any" }, "text": "産土神。生まれた土地の守り神。引っ越しても、最初の土地の神は、ついてくるという。……ふるさとは、そういうもの。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_colors", "category": "trivia", "conditions": { "visitor": "any" }, "text": "日本の色の名前は、千を超える。“東雲”、“月白”、“群青”……色ひとつに、情景がある。記録者泣かせで、記録者冥利。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_yaoyorozu_count", "category": "trivia", "conditions": { "visitor": "any" }, "text": "“八百万”は、ちょうど八百万柱、という意味じゃない。数えきれないほど、ということ。……多すぎて数えない。それが、この国の神の流儀。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_wa_itadakimasu", "category": "trivia", "conditions": { "visitor": "any" }, "text": "“いただきます”は、命を頂くことへの言葉。……食べるのは、誰かの記録を、引き継ぐことでもある。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_daily_sky", "category": "trivia", "conditions": { "visitor": "any" }, "text": "空が青いのは、レイリー散乱。波長の短い青い光ほど、大気の分子によく散らばる。夕焼けが赤いのは、その裏返し。……空の色は、光の散らばり方の記録。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_stardust", "category": "trivia", "conditions": { "visitor": "any" }, "text": "体を作る炭素も酸素も、昔どこかの星の中で生まれた。……人は、星の燃えかす。ロマンチックに言えば、ね。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_ice", "category": "trivia", "conditions": { "visitor": "any" }, "text": "氷が白く濁るのは、中に閉じ込められた無数の気泡が光を散らすから。ゆっくり凍らせると、透き通る。……急ぐと、濁る。何でもそう。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_onion", "category": "trivia", "conditions": { "visitor": "any" }, "text": "玉ねぎで涙が出るのは、切ると硫黄化合物が刺激物に変わるから。冷やすと、反応が鈍る。……泣かせるのにも、化学がある。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_rainbow", "category": "trivia", "conditions": { "visitor": "any" }, "text": "虹が七色に見えるのは、光が水滴で波長ごとに違う角度に曲がるから。……本当は、色の境目なんて無い。ぜんぶ、連続してる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_atoms", "category": "trivia", "conditions": { "visitor": "any" }, "text": "人の体の原子は、数年でほとんど入れ替わる。……“同じ自分”でいられるのは、案外ふしぎなこと。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_daily_thunder", "category": "trivia", "conditions": { "visitor": "any" }, "text": "稲光が見えてから雷鳴までの秒数を三で割ると、雷までのおよそのキロ数。……音は、光にずいぶん遅れる。", "expression": "neutral", "weight": 0.7 },

  { "id": "idle_work_01", "category": "idle", "conditions": { "visitor": "any" }, "text": "……この星の記録を、更新。異常なし。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_02", "category": "idle", "conditions": { "visitor": "any" }, "text": "観測ログ、書き足しておく。……今日のぶん。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_03", "category": "idle", "conditions": { "visitor": "any" }, "text": "座標を、合わせ直す。……少し、ずれてた。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_04", "category": "idle", "conditions": { "visitor": "any" }, "text": "手元の灯を、調整。……暗いと、書き損じる。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_05", "category": "idle", "conditions": { "visitor": "any" }, "text": "観測率、いま……六割ほど。悪くない数字。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_06", "category": "idle", "conditions": { "visitor": "any" }, "text": "古い記録を、読み返してる。……昔のわたしの字、雑ね。", "expression": "shy", "weight": 1 },
  { "id": "idle_work_07", "category": "idle", "conditions": { "visitor": "any" }, "text": "栞を、次の頁へ。……ここまで、視た。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_08", "category": "idle", "conditions": { "visitor": "any" }, "text": "筆を、少し置く。……目を休めるのも、仕事のうち。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_09", "category": "idle", "conditions": { "visitor": "any" }, "text": "新しい観察者を、名簿に加える。……ようこそ。", "expression": "smile", "weight": 1 },
  { "id": "idle_work_10", "category": "idle", "conditions": { "visitor": "any" }, "text": "レンズに、埃。……拭いておく。曇ったままだと、視え損なう。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_11", "category": "idle", "conditions": { "visitor": "any" }, "text": "今日の空模様も、記録に添える。……天気も、立派な観測対象。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_12", "category": "idle", "conditions": { "hourJST": [1, 5], "visitor": "any" }, "text": "深夜の観測は、捗る。……人が寝てるあいだも、世界は動いてる。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_13", "category": "idle", "conditions": { "visitor": "any" }, "text": "報告書の下書き。……“概ね平穏”。いい一日の、証。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_14", "category": "idle", "conditions": { "visitor": "any" }, "text": "墨が、切れかけ。……補充しておかないと。", "expression": "neutral", "weight": 1 },
  { "id": "idle_work_15", "category": "idle", "conditions": { "visitor": "any" }, "text": "空気を、入れ替える。……籠ると、集中が濁るから。", "expression": "neutral", "weight": 1 },

  { "id": "click_trivia_body_skeleton", "category": "trivia", "conditions": { "visitor": "any" }, "text": "骨は、常に作り替えられてる。だいたい十年で、全身が入れ替わる計算。……“同じ骨”のまま、生きてはいない。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_body_intestine", "category": "trivia", "conditions": { "visitor": "any" }, "text": "小腸は、伸ばすと7メートルほど。それを、お腹に折り畳んで収めてる。……体の中は、意外と広い。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_body_nerve", "category": "trivia", "conditions": { "visitor": "any" }, "text": "神経の信号は、速いもので時速300キロ近く。……熱い、と感じてから手を引くまで、体は全力で走ってる。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_body_enamel", "category": "trivia", "conditions": { "visitor": "any" }, "text": "体でいちばん硬いのは、歯のエナメル質。骨より硬い。……なのに、再生はしない。大事にしないと。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_body_stomach", "category": "trivia", "conditions": { "visitor": "any" }, "text": "胃の中は、金属も溶かすほどの酸。だけど胃自身は溶けない。粘液で、毎日守り直してるから。……自分を守るのも、仕事のうち。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_phys_glass", "category": "trivia", "conditions": { "visitor": "any" }, "text": "“ガラスはゆっくり流れる液体”――あれは、俗説。古い窓の下が厚いのは、昔の作り方と据え付けのせい。ガラスは、ちゃんと固体。……もっともらしい嘘は、記録を惑わす。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_phys_entangle", "category": "trivia", "conditions": { "visitor": "any" }, "text": "二つの粒子がもつれ合うと、どれだけ離れても、片方を測ればもう片方が決まる。……アインシュタインが“不気味な遠隔作用”と呼んだ。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_phys_zero", "category": "trivia", "conditions": { "visitor": "any" }, "text": "絶対零度、マイナス273.15度。原子の動きが、ほぼ止まる温度。……それより冷たくは、できない。世界にも、底がある。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_phys_superfluid", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ヘリウムは、うんと冷やすと超流動になる。抵抗ゼロで、容器の壁を這い上がる。……物理は、時々、行儀が悪い。", "expression": "mischief", "weight": 0.7 },
  { "id": "click_trivia_phys_mpemba", "category": "trivia", "conditions": { "visitor": "any" }, "text": "条件によっては、熱い水のほうが早く凍ることがある。ムペンバ効果。理由は、まだ議論の途中。……当たり前が、当たり前じゃない。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_hist_concrete", "category": "trivia", "conditions": { "visitor": "any" }, "text": "古代ローマの建物が二千年もつのは、コンクリートに混ぜた生石灰の粒。ひびに水が入ると溶けて固まり、勝手に塞ぐ。……自分で治る石。最近になって、やっと分かった。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_hist_cleopatra", "category": "trivia", "conditions": { "visitor": "any" }, "text": "クレオパトラが生きた時代は、ピラミッド建設より、月着陸のほうに近い。……時間の遠近は、直感を裏切る。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_hist_oxford", "category": "trivia", "conditions": { "visitor": "any" }, "text": "オックスフォード大学は、アステカ帝国より古い。……“古い”と“新しい”は、並べてみないと分からない。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_hist_alexandria", "category": "trivia", "conditions": { "visitor": "any" }, "text": "アレクサンドリアの図書館。古代の知が集まり、そして失われた。……記録者にとって、いちばん、こわい話。", "expression": "sad", "weight": 0.7 },

  { "id": "click_trivia_sea_unmapped", "category": "trivia", "conditions": { "visitor": "any" }, "text": "深海は、火星の地表より、地図が少ない。……いちばん遠い場所は、案外、足元の海。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_sea_biolum", "category": "trivia", "conditions": { "visitor": "any" }, "text": "深海の生き物の多くは、自分で光る。暗闇で、餌を釣り、仲間を呼ぶ。……光のない世界で、光を作る。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_sea_pressure", "category": "trivia", "conditions": { "visitor": "any" }, "text": "いちばん深い海の底は、指先に象が何頭も乗るほどの水圧。……それでも、生き物はいる。命は、しぶとい。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_math_birthday", "category": "trivia", "conditions": { "visitor": "any" }, "text": "23人いれば、同じ誕生日の二人がいる確率が、半分を超える。……直感は、数のことになると、よく間違える。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_math_pi", "category": "trivia", "conditions": { "visitor": "any" }, "text": "円周率は、終わらないし、繰り返さない。あなたの誕生日の並びも、どこかにあるかもしれない。……無限は、何でも呑み込む。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_math_googol", "category": "trivia", "conditions": { "visitor": "any" }, "text": "1のあとに0を百個。“グーゴル”。宇宙にある原子より、大きな数。……名前があるだけで、少し、身近。", "expression": "neutral", "weight": 0.7 },

  { "id": "click_trivia_qm_doubleslit", "category": "trivia", "conditions": { "visitor": "any" }, "text": "二重スリット実験。電子は、誰も見ていないと、波のように両方の隙間を同時に通る。……“どちらを通ったか”を観測した瞬間、粒に戻る。観測が、世界を決めてしまう。……わたしたちの、仕事の話みたい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_qm_feynman", "category": "trivia", "conditions": { "visitor": "any" }, "text": "ファインマンは、量子の不思議はぜんぶ、あの二重スリットに詰まってる、と言った。……“唯一の謎”。何度読んでも、ぞくぞくする。", "expression": "smile", "weight": 0.7 },
  { "id": "click_trivia_qm_cat", "category": "trivia", "conditions": { "visitor": "any" }, "text": "シュレーディンガーの猫。箱を開けるまで、猫は生きていて、同時に死んでいる。観測するまで、答えは決まらない。……箱を開けるの、少しこわい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_qm_uncertainty", "category": "trivia", "conditions": { "visitor": "any" }, "text": "不確定性原理。位置を正確に知るほど、速度は曖昧になる。……ぜんぶを同時には、視られない。観測者への、戒めみたい。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_qm_tunnel", "category": "trivia", "conditions": { "visitor": "any" }, "text": "太陽が輝けるのは、量子トンネル効果のおかげ。本来なら越えられない壁を、確率でわずかに通り抜けて、水素が融合する。……あり得ないことが起きるから、朝が来る。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_qm_vacuum", "category": "trivia", "conditions": { "visitor": "any" }, "text": "“何もない”はずの真空でも、粒子が生まれては、消えてる。……完全な無は、存在しない。宇宙は、じっとしていられない。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_qm_zeno", "category": "trivia", "conditions": { "visitor": "any" }, "text": "見つめ続けると、量子は変化できなくなる。“量子ゼノン効果”。……観測が、時を止める。……見すぎるのも、罪ね。", "expression": "neutral", "weight": 0.7 },
  { "id": "click_trivia_qm_collapse", "category": "trivia", "conditions": { "visitor": "any" }, "text": "波束の収縮。可能性の波が、観測の瞬間に、ひとつの答えへ畳まれる。……視ることは、選ぶこと。観測者の、責任。", "expression": "neutral", "weight": 0.7 },

  { "id": "anomaly_measurement", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "未解決記録……“観測すると、なぜ答えが決まるのか”。量子力学の心臓部。百年、誰も、本当のところを知らない。……観測者なのに、観測の意味が、わからない。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_manyworlds", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "多世界解釈……観測のたびに、世界が枝分かれする、という考え。選ばなかったほうのわたしも、どこかで記録をつけてる。……かもしれない。", "expression": "neutral", "weight": 0.3 },

  { "id": "anomaly_wow", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "異常検知ログ……1977年、宇宙から72秒だけ届いた電波。“Wow!”と走り書きされて、以来、二度と鳴らない。……返事を、しそびれた気がする。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_whale52", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "異常検知……52ヘルツで鳴く鯨。誰にも届かない声で、何十年も歌ってる。“世界一孤独な鯨”。……この部屋の声は、届いてるといい。", "expression": "sad", "weight": 0.3 },
  { "id": "anomaly_voynich", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "解読不能の記録……ヴォイニッチ手稿。六百年、誰も読めない文字と、実在しない植物の絵。……記録者として、少し、悔しい。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_attractor", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "観測異常……“グレート・アトラクター”。天の川の陰に隠れて、無数の銀河を、何かが引き寄せてる。正体は、まだ視えない。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_void", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "うしかい座の方向に、ぽっかり空いた領域。何億光年も、ほとんど何もない。……宇宙にも、空白のページがある。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_schumann", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "地表と電離層のあいだに、7.83ヘルツの共振。世界中の雷が、地球を鳴らしてる。……惑星の、低い唸り。気になる音。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_numbers", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "短波の向こうで、数字だけを読み上げ続ける放送。誰が、誰に向けて。……“異常検知ログ”に、また一件。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_antikythera", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "二千年前の海から、歯車の機械。星の運行を計算する、古代の道具。……失われた技術には、記録さえ、追いつけない。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_oumuamua", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "太陽系を、別の星から来た何かが通り過ぎた。細長くて、加速して、去っていった。名は“オウムアムア”。……挨拶する間も、なかった。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_darkmatter", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "宇宙のほとんどは、視えない何か。“暗黒物質”。触れられないのに、銀河を繋ぎとめてる。……視えないものを、どう記録しよう。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_fermi", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "これだけ星があって、どうして、こんなに静か。……“みんな、どこにいる？”。答えの出ない問い。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_hum", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "一部の人にだけ聞こえる、低い唸り。“ハム”。原因は、まだ不明。……あなたにも、聞こえてる？", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_nwo", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "異常検知ログ……“New World Order”。……誰かの、走り書き。意味は、わからない。記録だけ、しておく。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_hoshikui", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "異常検知ログ……“星喰”の座標が、また、ずれた。記録上は、存在しないはずの領域。……見なかったことに、しておく。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_clavis", "category": "anomaly", "conditions": { "visitor": "any" }, "text": "クラヴィス・ロア……“鍵”、という意味だけは分かる。何を開ける鍵かは、記録に、無い。……気になる言葉。", "expression": "neutral", "weight": 0.3 },
  { "id": "anomaly_ratio", "category": "anomaly", "conditions": { "hourJST": [1, 5], "visitor": "any" }, "text": "観測率が、数えた観察者より、多い日がある。……誰が、視てるんだろう。", "expression": "neutral", "weight": 0.25 },

  { "id": "prog_morning_01", "category": "program:morning", "conditions": { "hourJST": [6, 11] }, "text": "朝の観測、はじめます。……今日は何が視えるかな。", "expression": "neutral", "weight": 1 },
  { "id": "prog_morning_02", "category": "program:morning", "conditions": { "hourJST": [6, 11] }, "text": "朝の観測。……日の光で、記録の間がよく見える。", "expression": "neutral", "weight": 1 },
  { "id": "prog_daytime_01", "category": "program:daytime", "conditions": { "hourJST": [11, 18] }, "text": "ひるの雑記。とりとめのない話を、少し。", "expression": "neutral", "weight": 1 },
  { "id": "prog_daytime_02", "category": "program:daytime", "conditions": { "hourJST": [11, 18] }, "text": "ひるの雑記。……眠くならないうちに、進めましょう。", "expression": "neutral", "weight": 1 },
  { "id": "prog_night_01", "category": "program:night", "conditions": { "hourJST": [18, 25] }, "text": "夜の観測録。……声を、落として。", "expression": "neutral", "weight": 1 },
  { "id": "prog_night_02", "category": "program:night", "conditions": { "hourJST": [18, 25] }, "text": "夜の観測録。空が暗いほど、星はよく視える。", "expression": "neutral", "weight": 1 },
  { "id": "prog_midnight_01", "category": "program:midnight", "conditions": { "hourJST": [1, 6] }, "text": "静かな時間。眠れない者だけの、時間。", "expression": "neutral", "weight": 1 },
  { "id": "prog_midnight_02", "category": "program:midnight", "conditions": { "hourJST": [1, 6] }, "text": "静かな時間。……無理に、起きていなくてもいいのよ。", "expression": "neutral", "weight": 1 },

  { "id": "promo_01", "category": "promo", "conditions": { "visitor": "any" }, "text": "続きを視たいなら……窓口、そこに。無理はしないで。", "expression": "neutral", "weight": 1 },
  { "id": "promo_02", "category": "promo", "conditions": { "visitor": "any" }, "text": "記録を残す手伝いをしてくれる人へ。……感謝を、ひとつ。", "expression": "smile", "weight": 1 },
  { "id": "promo_03", "category": "promo", "conditions": { "visitor": "any" }, "text": "支援の窓口、そこに置いておくね。……見るだけでも、いい。", "expression": "neutral", "weight": 1 },
  { "id": "promo_04", "category": "promo", "conditions": { "visitor": "any" }, "text": "この部屋を続けるのに、少しだけ力を借りてる。……ありがとう。それだけ。", "expression": "smile", "weight": 1 },

  { "id": "date_0101_newyear", "category": "idle", "conditions": { "dateJST": { "from": "01-01", "to": "01-03" }, "visitor": "any" }, "text": "あけましておめでとう。……今年も、この箱庭を視ていく。", "expression": "smile", "weight": 2 },
  { "id": "date_0203_setsubun", "category": "idle", "conditions": { "dateJST": { "from": "02-02", "to": "02-03" }, "visitor": "any" }, "text": "節分。豆を撒いて、鬼を祓う。……境目の日は、昔から特別なの。", "expression": "neutral", "weight": 2 },
  { "id": "date_0303_hina", "category": "idle", "conditions": { "dateJST": { "from": "03-01", "to": "03-03" }, "visitor": "any" }, "text": "桃の節句。雛人形は、災いの身代わり。……人の形に、厄を移すの。", "expression": "neutral", "weight": 2 },
  { "id": "date_0321_shunbun", "category": "idle", "conditions": { "dateJST": { "from": "03-19", "to": "03-22" }, "visitor": "any" }, "text": "春分。昼と夜が、ちょうど半分ずつ。……釣り合う日は、なんだか落ち着く。", "expression": "neutral", "weight": 2 },
  { "id": "date_0505_tango", "category": "idle", "conditions": { "dateJST": { "from": "05-04", "to": "05-05" }, "visitor": "any" }, "text": "端午の節句。菖蒲は、邪気祓い。……香りの強いものは、昔から魔除けなの。", "expression": "neutral", "weight": 2 },
  { "id": "date_0707_tanabata", "category": "idle", "conditions": { "dateJST": { "from": "07-05", "to": "07-08" }, "visitor": "any" }, "text": "もうすぐ、星今宵の時期。……願いごとは、決まった？", "expression": "smile", "weight": 2 },
  { "id": "date_0815_obon", "category": "idle", "conditions": { "dateJST": { "from": "08-13", "to": "08-16" }, "visitor": "any" }, "text": "お盆。帰ってくる魂を、迎え火で導く。……送るときは、少しさみしい。", "expression": "sad", "weight": 2 },
  { "id": "date_0923_shubun", "category": "idle", "conditions": { "dateJST": { "from": "09-21", "to": "09-24" }, "visitor": "any" }, "text": "秋分。彼岸。……こちらとあちらが、いちばん近づく頃、なのだそう。", "expression": "neutral", "weight": 2 },
  { "id": "date_1031_full_autumn", "category": "idle", "conditions": { "dateJST": { "from": "10-30", "to": "10-31" }, "visitor": "any" }, "text": "西の国では、今夜は死者が還る日、と言うらしい。……境目は、世界のどこにでもある。", "expression": "neutral", "weight": 2 },
  { "id": "date_1221_toji", "category": "idle", "conditions": { "dateJST": { "from": "12-20", "to": "12-23" }, "visitor": "any" }, "text": "一年で、いちばん夜が長い日。……こういう日は、少し嬉しい。", "expression": "smile", "weight": 2 },
  { "id": "date_1231_omisoka", "category": "idle", "conditions": { "dateJST": { "from": "12-30", "to": "12-31" }, "visitor": "any" }, "text": "大晦日。一年分の記録を、閉じる。……よく、続いたね。", "expression": "smile", "weight": 2 },

  { "id": "season_spring_01", "category": "idle", "conditions": { "season": "spring", "visitor": "any" }, "text": "風がぬるい。……そろそろ、桜。散り際がいちばん、記録し甲斐がある。", "expression": "neutral", "weight": 1.5 },
  { "id": "season_spring_02", "category": "idle", "conditions": { "season": "spring", "visitor": "any" }, "text": "芽が出てる。……冬をこえたもの。えらいね。", "expression": "smile", "weight": 1.5 },
  { "id": "season_summer_01", "category": "idle", "conditions": { "season": "summer", "visitor": "any" }, "text": "蝉の声。……うるさいけど、これがないと夏じゃない。", "expression": "neutral", "weight": 1.5 },
  { "id": "season_summer_02", "category": "idle", "conditions": { "season": "summer", "visitor": "any" }, "text": "夕立が来そう。……羽織、湿気で重い。", "expression": "neutral", "weight": 1.5 },
  { "id": "season_summerend_01", "category": "idle", "conditions": { "season": "summer_end", "visitor": "any" }, "text": "葉が落ちた。……一葉の秋。夏も、終わるね。", "expression": "sad", "weight": 1.5 },
  { "id": "season_summerend_02", "category": "idle", "conditions": { "season": "summer_end", "visitor": "any" }, "text": "蝉の声が、遠くなった。……夏の終わりは、いつも急ぎ足。", "expression": "sad", "weight": 1.5 },
  { "id": "season_autumn_01", "category": "idle", "conditions": { "season": "autumn", "visitor": "any" }, "text": "日が短くなった。……釣瓶落とし、って言うの。", "expression": "neutral", "weight": 1.5 },
  { "id": "season_autumn_02", "category": "idle", "conditions": { "season": "autumn", "visitor": "any" }, "text": "月がきれい。……秋の空は、澄んでる。観測日和。", "expression": "smile", "weight": 1.5 },
  { "id": "season_winter_01", "category": "idle", "conditions": { "season": "winter", "visitor": "any" }, "text": "息が白い。……こういう静けさは、嫌いじゃない。", "expression": "neutral", "weight": 1.5 },
  { "id": "season_winter_02", "category": "idle", "conditions": { "season": "winter", "visitor": "any" }, "text": "手が冷たい。……火鉢が、恋しい。", "expression": "neutral", "weight": 1.5 },

  { "id": "weather_clear_01", "category": "idle", "conditions": { "weather": "clear", "visitor": "any" }, "text": "よく晴れた。……夜は星が視えるかも。", "expression": "smile", "weight": 1.5 },
  { "id": "weather_clear_02", "category": "idle", "conditions": { "weather": "clear", "visitor": "any" }, "text": "雲ひとつない。……観測率、期待できる。", "expression": "neutral", "weight": 1.5 },
  { "id": "weather_cloud_01", "category": "idle", "conditions": { "weather": "cloud", "visitor": "any" }, "text": "今日は、雲。……星は、おあずけね。", "expression": "neutral", "weight": 1.5 },
  { "id": "weather_rain_01", "category": "idle", "conditions": { "weather": "rain", "visitor": "any" }, "text": "雨の音。……こういう日は、視聴者も静か。落ち着く。", "expression": "neutral", "weight": 1.5 },
  { "id": "weather_rain_02", "category": "idle", "conditions": { "weather": "rain", "visitor": "any" }, "text": "雨。……水は、いろんなものを運ぶ。音も、においも。", "expression": "neutral", "weight": 1.5 },
  { "id": "weather_snow_01", "category": "idle", "conditions": { "weather": "snow", "visitor": "any" }, "text": "雪。……積もったら、明日の記録が白くなる。", "expression": "smile", "weight": 1.5 },
  { "id": "weather_snow_02", "category": "idle", "conditions": { "weather": "snow", "visitor": "any" }, "text": "静かに降ってる。……雪の日は、世界が音を吸う。", "expression": "neutral", "weight": 1.5 },

  { "id": "poly_latin_adastra", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Ad astra. ……昔の観測者の、口癖。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_latin_memento", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Memento. ……いちばん大事な仕事。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_latin_peraspera", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Per aspera. ……ふ。今のは、内緒。", "expression": "mischief", "weight": 0.25 },
  { "id": "poly_latin_alea", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Alea iacta est. ……たまに、そんな日もある。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_latin_lux", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Post tenebras, lux. ……好きな言葉。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_latin_sicitur", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Sic itur ad astra. ……また、星の話。癖なの。", "expression": "shy", "weight": 0.25 },
  { "id": "poly_latin_vita", "category": "idle", "conditions": { "visitor": "any" }, "lang": "la", "text": "Ars longa, vita brevis. ……だから、記録するの。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_en_evening", "category": "idle", "conditions": { "hourJST": [17, 25], "visitor": "any" }, "lang": "en", "text": "…Good evening. ……なんて、ね。", "expression": "shy", "weight": 0.25 },
  { "id": "poly_en_starlight", "category": "idle", "conditions": { "visitor": "any" }, "lang": "en", "text": "Starlight. …The light is old. ……つい、英語で。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_en_welcome", "category": "greeting", "conditions": { "visitor": "first" }, "lang": "en", "text": "Welcome. ……ようこそ、のほう。", "expression": "smile", "weight": 0.25 },
  { "id": "poly_zh_nihao", "category": "greeting", "conditions": { "visitor": "any" }, "lang": "zh", "text": "你好。……遠くの箱庭にも、観測者はいる。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_zh_star", "category": "idle", "conditions": { "visitor": "any" }, "lang": "zh", "text": "星河。……同じ空を、別の言葉で呼ぶ。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_ko_annyeong", "category": "greeting", "conditions": { "visitor": "any" }, "lang": "ko", "text": "안녕하세요. ……空は、同じ。", "expression": "neutral", "weight": 0.25 },
  { "id": "poly_ko_night", "category": "idle", "conditions": { "hourJST": [18, 25], "visitor": "any" }, "lang": "ko", "text": "좋은 밤. ……夜の挨拶。", "expression": "neutral", "weight": 0.25 }
]
